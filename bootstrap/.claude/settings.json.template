{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "Bash(git rev-parse:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh api:*)",
      "Bash(./bin/refresh:*)",
      "Bash(./bin/setup:*)",
      "Bash(./bin/preferences-check:*)",
      "Bash(./bin/repo-config:*)",
      "Bash(./bin/contacts:*)",
      "Bash(./bin/validate-internal-links:*)",
      "Bash(./bin/validate-task-spec:*)",
      "Bash(jq:*)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(rm -rf:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/scripts/session-start-stale-check.sh 2>&1 | jq -Rs '{hookSpecificOutput:{hookEventName:\"SessionStart\",additionalContext:.}}'",
            "timeout": 10,
            "statusMessage": "Stale-state check…"
          }
        ]
      }
    ]
  }
}
