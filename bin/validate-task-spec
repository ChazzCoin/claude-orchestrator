#!/usr/bin/env bash
#
# bin/validate-task-spec — validate a task or proposal markdown file.
#
# Output: Pattern 6 — Severity audit
#         (per-finding lines with location and reason; final pass/fail
#          summary; see .claude/output-catalogue.md)
#
# Usage:
#   bin/validate-task-spec <path-to-task-md>
#   bin/validate-task-spec --json <path-to-task-md>
#   bin/validate-task-spec --quiet <path-to-task-md>   # exit code only
#
# Behavior:
#   Checks the file conforms to kit/governance/task-spec-shape.md:
#   - Frontmatter delimiters present (--- … ---)
#   - All 9 required body sections present:
#       User request, Why, Assumptions, Technical breakdown,
#       Acceptance criteria, Out of scope, Contract impact,
#       References, Definition of done
#   - Acceptance criteria has ≥1 checkbox entry (- [ ] or - [x])
#   - References has ≥1 bullet entry (- ...)
#
# Exit codes:
#   0 — valid
#   1 — invalid (errors printed)
#   2 — usage error
#
# Used by /promote (refuses to promote an invalid task), /propose new
# (warns at draft time), and any future skill that authors task specs.

set -euo pipefail

JSON_OUTPUT=0
QUIET=0
FILE=""

for arg in "$@"; do
  case "$arg" in
    --json) JSON_OUTPUT=1 ;;
    --quiet) QUIET=1 ;;
    -h|--help)
      grep '^#' "$0" | head -30 | sed 's/^# \?//'
      exit 0
      ;;
    -*) echo "unknown flag: $arg" >&2; exit 2 ;;
    *)
      [ -n "$FILE" ] && { echo "multiple files not supported" >&2; exit 2; }
      FILE="$arg"
      ;;
  esac
done

if [ -z "$FILE" ]; then
  echo "usage: bin/validate-task-spec [--json] [--quiet] <path-to-task-md>" >&2
  exit 2
fi
if [ ! -f "$FILE" ]; then
  echo "no such file: $FILE" >&2
  exit 2
fi

REQUIRED_SECTIONS=(
  "## User request"
  "## Why"
  "## Assumptions"
  "## Technical breakdown"
  "## Acceptance criteria"
  "## Out of scope"
  "## Contract impact"
  "## References"
  "## Definition of done"
)

ERRORS=()

# Frontmatter open
if [ "$(head -1 "$FILE")" != "---" ]; then
  ERRORS+=("line 1: missing frontmatter delimiter (expected ---)")
fi

# Frontmatter close (second --- found in file)
fm_close=$(awk '/^---$/ { count++; if (count == 2) { print NR; exit } }' "$FILE" || true)
if [ -z "$fm_close" ]; then
  ERRORS+=("frontmatter has no closing delimiter")
fi

# Required body sections (exact heading match, anchored to start of line)
for section in "${REQUIRED_SECTIONS[@]}"; do
  if ! grep -qE "^${section}\$" "$FILE"; then
    ERRORS+=("missing required section: $section")
  fi
done

# Acceptance criteria must have at least one checkbox
ac_body=$(awk '
  /^## Acceptance criteria$/ { flag=1; next }
  /^## / { flag=0 }
  flag { print }
' "$FILE")
if [ -n "$ac_body" ]; then
  if ! echo "$ac_body" | grep -qE '^- \[[ xX]\]'; then
    ERRORS+=("## Acceptance criteria has no checkbox entries (need - [ ] or - [x])")
  fi
fi

# References must have at least one bullet
ref_body=$(awk '
  /^## References$/ { flag=1; next }
  /^## / { flag=0 }
  flag { print }
' "$FILE")
if [ -n "$ref_body" ]; then
  if ! echo "$ref_body" | grep -qE '^- '; then
    ERRORS+=("## References has no entries (need at least one bullet)")
  fi
fi

# Output
n_errors=${#ERRORS[@]}

if [ "$JSON_OUTPUT" -eq 1 ]; then
  if [ "$n_errors" -eq 0 ]; then
    printf '{"file":"%s","valid":true,"errors":[]}\n' "$FILE"
  else
    printf '{"file":"%s","valid":false,"errors":[' "$FILE"
    for i in "${!ERRORS[@]}"; do
      [ "$i" -gt 0 ] && printf ','
      esc="${ERRORS[$i]//\\/\\\\}"
      esc="${esc//\"/\\\"}"
      printf '"%s"' "$esc"
    done
    printf ']}\n'
  fi
elif [ "$QUIET" -eq 0 ]; then
  if [ "$n_errors" -eq 0 ]; then
    echo "✓ $FILE: valid task spec"
  else
    echo "✗ $FILE: $n_errors error(s)"
    for err in "${ERRORS[@]}"; do
      echo "  $err"
    done
  fi
fi

[ "$n_errors" -eq 0 ] && exit 0 || exit 1
